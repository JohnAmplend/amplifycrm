{
  "name": "Contact",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "description": "Contact first name"
    },
    "last_name": {
      "type": "string",
      "description": "Contact last name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "mobile": {
      "type": "string",
      "description": "Mobile number"
    },
    "job_title": {
      "type": "string",
      "description": "Job title"
    },
    "department": {
      "type": "string",
      "description": "Department"
    },
    "company_id": {
      "type": "string",
      "description": "Associated company ID"
    },
    "contact_owner": {
      "type": "string",
      "description": "User email who owns this contact"
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "Subscriber",
        "Lead",
        "MQL",
        "SQL",
        "Opportunity",
        "Customer"
      ],
      "default": "Lead",
      "description": "Current lifecycle stage"
    },
    "lead_status": {
      "type": "string",
      "enum": [
        "New",
        "Attempting",
        "Connected",
        "Qualified",
        "Unqualified"
      ],
      "default": "New",
      "description": "Lead status"
    },
    "address": {
      "type": "string",
      "description": "Street address"
    },
    "city": {
      "type": "string",
      "description": "City"
    },
    "state": {
      "type": "string",
      "description": "State/Province"
    },
    "zip": {
      "type": "string",
      "description": "Zip/Postal code"
    },
    "country": {
      "type": "string",
      "description": "Country"
    },
    "linkedin_url": {
      "type": "string",
      "description": "LinkedIn profile URL"
    },
    "twitter_handle": {
      "type": "string",
      "description": "Twitter handle"
    },
    "facebook_url": {
      "type": "string",
      "description": "Facebook profile URL"
    },
    "time_zone": {
      "type": "string",
      "description": "Contact's time zone"
    },
    "lead_source": {
      "type": "string",
      "description": "How the contact was acquired"
    },
    "original_source": {
      "type": "string",
      "description": "Original source of the contact"
    },
    "latest_source": {
      "type": "string",
      "description": "Most recent source"
    },
    "first_conversion_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date of first conversion"
    },
    "recent_conversion_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date of most recent conversion"
    },
    "marketing_emails_opened": {
      "type": "number",
      "description": "Number of marketing emails opened"
    },
    "marketing_emails_clicked": {
      "type": "number",
      "description": "Number of marketing emails clicked"
    },
    "last_contacted": {
      "type": "string",
      "format": "date-time",
      "description": "Date last contacted"
    },
    "next_activity_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date of next scheduled activity"
    },
    "industry": {
      "type": "string",
      "description": "Industry sector"
    },
    "number_of_employees": {
      "type": "number",
      "description": "Number of employees at contact's company"
    },
    "annual_revenue": {
      "type": "number",
      "description": "Annual revenue of contact's company"
    },
    "company_website": {
      "type": "string",
      "description": "Company website URL"
    },
    "company_domain": {
      "type": "string",
      "description": "Company domain name"
    },
    "close_date": {
      "type": "string",
      "format": "date",
      "description": "Expected close date"
    },
    "deal_amount": {
      "type": "number",
      "description": "Associated deal amount"
    },
    "deal_stage_name": {
      "type": "string",
      "description": "Associated deal stage"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorization"
    },
    "last_contacted_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date last contacted"
    },
    "last_activity_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date of last activity"
    },
    "custom_data": {
      "type": "object",
      "description": "Custom field values stored as JSON"
    }
