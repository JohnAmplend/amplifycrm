{
  "name": "Record_Note",
  "type": "object",
  "properties": {
    "record_type": {
      "type": "string",
      "enum": [
        "Contact",
        "Company",
        "Deal",
        "Lead",
        "Ticket"
      ],
      "description": "Type of record this note belongs to"
    },
    "record_id": {
      "type": "string",
      "description": "ID of the record"
    },
    "note_content": {
      "type": "string",
      "description": "Note content"
    },
    "note_type": {
      "type": "string",
      "enum": [
        "Note",
        "Comment",
        "Internal"
      ],
      "default": "Note",
      "description": "Type of note"
    },
    "mentions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of mentioned user emails"
    },
    "is_pinned": {
      "type": "boolean",
      "default": false,
      "description": "Whether note is pinned"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "Everyone",
        "Team",
        "Private"
      ],
      "default": "Everyone",
      "description": "Who can see this note"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "File URLs attached to note"
    }
  },
  "required": [
    "record_type",
    "record_id",
    "note_content"
  ]
}