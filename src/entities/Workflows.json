{
  "name": "Workflows",
  "type": "object",
  "properties": {
    "workflow_name": {
      "type": "string",
      "description": "Workflow name"
    },
    "workflow_description": {
      "type": "string",
      "description": "Workflow description"
    },
    "trigger_type": {
      "type": "string",
      "enum": [
        "Record Created",
        "Record Updated",
        "Form Submitted",
        "Email Opened",
        "Deal Stage Changed",
        "Time-Based",
        "Manual"
      ],
      "description": "Trigger type"
    },
    "trigger_object": {
      "type": "string",
      "enum": [
        "Contact",
        "Company",
        "Deal",
        "Lead",
        "Ticket",
        "Custom Object"
      ],
      "description": "Object that triggers workflow"
    },
    "trigger_conditions": {
      "type": "object",
      "description": "Conditions that must be met"
    },
    "is_active": {
      "type": "boolean",
      "default": false,
      "description": "Whether workflow is active"
    },
    "execution_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times executed"
    },
    "last_executed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last execution timestamp"
    },
    "created_by": {
      "type": "string",
      "description": "User who created"
    }
  },
  "required": [
    "workflow_name",
    "trigger_type",
    "trigger_object"
  ]
}