{
  "name": "Customer_Portal_Access",
  "type": "object",
  "properties": {
    "contact_id": {
      "type": "string",
      "description": "Associated contact ID"
    },
    "portal_email": {
      "type": "string",
      "format": "email",
      "description": "Email for portal login"
    },
    "password_hash": {
      "type": "string",
      "description": "Hashed password"
    },
    "last_login": {
      "type": "string",
      "format": "date-time",
      "description": "Last login timestamp"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether access is active"
    },
    "access_token": {
      "type": "string",
      "description": "Current access token"
    }
  },
  "required": [
    "contact_id",
    "portal_email"
  ]
}